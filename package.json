{
	"name": "@lesjoursfr/gifsicle-wrapper",
	"version": "6.0.1",
	"description": "Wrapper for Gifsicle",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lesjoursfr/gifsicle-wrapper.git"
	},
	"homepage": "https://github.com/lesjoursfr/gifsicle-wrapper#readme",
	"bugs": {
		"url": "https://github.com/lesjoursfr/gifsicle-wrapper/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": "22.x || 24.x || 26.x"
	},
	"keywords": [
		"gif",
		"gifsicle",
		"image",
		"img",
		"compress",
		"resize",
		"minify",
		"optimize"
	],
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"type": "module",
	"scripts": {
		"freshlock": "rm -rf node_modules/ && rm .yarn/install-state.gz && rm yarn.lock && yarn",
		"postinstall": "node install/install.js",
		"check-lint": "eslint",
		"check-format": "prettier --check .",
		"check-tsc": "tsc --noEmit",
		"lint": "eslint --fix",
		"format": "prettier --write .",
		"build-postinstall": "tsc --project tsconfig.install.json",
		"build": "tsc",
		"test": "NODE_OPTIONS='--loader=ts-node/esm' mocha"
	},
	"dependencies": {
		"@lesjoursfr/bin-wrapper": "^13.1.1",
		"execa": "^9.6.1",
		"image-size": "^2.0.2",
		"tar": "^7.5.15",
		"tempy": "^3.2.0"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@tsconfig/node22": "22.0.5",
		"@types/mocha": "10.0.10",
		"@types/node": "24.12.4",
		"eslint": "10.3.0",
		"eslint-config-prettier": "10.1.8",
		"globals": "17.6.0",
		"mocha": "11.7.5",
		"prettier": "3.8.3",
		"ts-node": "10.9.2",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.3"
	},
	"packageManager": "yarn@4.14.1"
}
